# =============================================================================
# secrets.toml.example  —  Modelo de configuração da PERSISTÊNCIA de dados
# =============================================================================
#
# POR QUE ISSO EXISTE
# -------------------
# No Streamlit Community Cloud o disco é EFÊMERO: tudo que o app grava no
# arquivo `Dataset/postos.db` é apagado quando o app reinicia, dorme ou é
# redistribuído. Para que os lançamentos NÃO se percam, após cada cadastro o
# banco é commitado e enviado (push) de volta para o GitHub — e é isso que
# faz os dados sobreviverem a reinícios.
#
# Sem a seção [github] abaixo, a sincronização fica DESATIVADA e os novos
# dados são perdidos no próximo reinício (era exatamente esse o problema).
#
# COMO ATIVAR (uma única vez)
# ---------------------------
# 1. Gere um Personal Access Token no GitHub com permissão de escrita no repo:
#    GitHub → Settings → Developer settings → Personal access tokens →
#    "Fine-grained tokens" → conceda "Contents: Read and write" a ESTE repositório.
#
# 2. No Streamlit Cloud: abra o app → Manage app → Settings → Secrets e cole
#    o conteúdo abaixo (com os seus valores). NÃO comite o token no repositório.
#
#    Para rodar localmente, copie este arquivo para `.streamlit/secrets.toml`
#    (sem o `.example`) e preencha os valores. Esse arquivo NÃO deve ir para o
#    git — mantenha-o no .gitignore.
#
# 3. Salve. O app passa a exibir "Sincronização com o GitHub ativa" na página
#    de Lançamento de Dados, e cada cadastro é persistido automaticamente.
# =============================================================================

[github]
# Personal Access Token com permissão de escrita (Contents: Read and write).
token = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Repositório no formato "usuario/nome-do-repo".
repo = "LuizDomingo27/APP_Postos"

# Branch de destino do push (opcional — padrão: "main").
branch = "main"

# Identidade usada nos commits automáticos (opcional).
committer_name = "App Postos Bot"
committer_email = "bot@example.com"
