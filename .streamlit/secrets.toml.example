# =============================================================================
# secrets.toml.example  —  Modelo de configuração do SUPABASE
# =============================================================================
#
# POR QUE ISSO EXISTE
# -------------------
# A aplicação usa o Supabase (Postgres gerenciado) como banco de dados
# principal — a tabela `postos` guarda todos os lançamentos. Sem a seção
# [supabase] abaixo, o app não consegue ler nem gravar nenhum dado.
#
# COMO ATIVAR (uma única vez)
# ---------------------------
# 1. No painel do Supabase: Project Settings → API.
#    - Copie a "Project URL" → campo `url` abaixo.
#    - Copie a chave "service_role" (secret) → campo `service_role_key`.
#      NUNCA use a chave "anon" aqui: a service_role é a única que tem
#      permissão de leitura/escrita irrestrita na tabela `postos` sem
#      depender de policies de Row Level Security.
#
# 2. No Streamlit Cloud: abra o app → Manage app → Settings → Secrets e cole
#    o conteúdo abaixo (com os seus valores). NÃO comite este arquivo
#    preenchido no repositório.
#
#    Para rodar localmente, copie este arquivo para `.streamlit/secrets.toml`
#    (sem o `.example`) e preencha os valores. Esse arquivo já está no
#    .gitignore — não deve ir para o git.
#
# 3. Garanta que a tabela `postos` já foi criada no Supabase — ver
#    `supabase/migrations/20260720120000_create_postos_table.sql` (execute
#    esse SQL uma vez no Supabase Dashboard → SQL Editor).
# =============================================================================

[supabase]
# URL do projeto, no formato "https://xxxxxxxxxxxx.supabase.co".
url = "https://xxxxxxxxxxxxxxxxxxxx.supabase.co"

# Chave "service_role" (Project Settings → API → Project API keys).
# Concede acesso total ao banco — mantenha em segredo, nunca a exponha no
# navegador ou em código versionado.
service_role_key = "eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
